{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./js",
    "target": "ES5",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["DOM", "ES2015"],
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "types": []
  },
  "include": ["js/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}